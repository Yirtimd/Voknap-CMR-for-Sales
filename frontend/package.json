{
  "name": "crm-sales-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run && npm run test:contrast",
    "test:contrast": "node scripts/check-contrast.mjs",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "screenshots": "playwright test --update-snapshots",
    "quality:p2": "npm run typecheck && npm test && npm run test:visual && npm run build",
    "build": "vue-tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.1.0"
  }
}
